rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /likes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow get: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /tokenCache/{doc} {
      allow read, write: if false;
    }

    match /shares/{shareId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /conversations/{convId} {
      // resource is null when the document does not exist.
      // Allow get on missing docs so clients can do get-then-create.
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Songs queued for contacts who haven't signed up yet. Clients may only
    // CREATE shares they personally sent; reads/updates/deletes happen
    // exclusively from Cloud Functions via the admin SDK.
    match /pendingShares/{phone}/shares/{shareId} {
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.keys().hasAll(['senderId', 'song', 'createdAt']);
      allow read, update, delete: if false;
    }

    // Claim-retry requests: a signed-in user asks the server to re-run the
    // pending-shares fan-out for their own UID. Processed and deleted by the
    // onClaimRequest Cloud Function.
    match /claimRequests/{reqId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
