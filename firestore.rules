rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // True when `recipient` has added `sender` to their blocked subcollection.
    // Used to forbid blocked users from writing into the blocker's inboxes.
    function isBlockedBy(recipient, sender) {
      return exists(/databases/$(database)/documents/users/$(recipient)/blocked/$(sender));
    }

    // For 2-person DMs, returns the non-sender participant uid.
    function otherParticipant(convId, senderUid) {
      let p = get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      return p[0] == senderUid ? p[1] : p[0];
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /likes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /friends/{friendId} {
        // Owner has full access to their own list. Peers (the "other user"
        // in the friendship) may CREATE and DELETE their own mirrored row —
        // this is what makes bidirectional add/unfriend work from a single
        // client — but cannot read each other's friend lists or overwrite
        // arbitrary fields.
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == friendId
          && !isBlockedBy(userId, request.auth.uid);
        allow delete: if request.auth != null && request.auth.uid == friendId;
      }

      // Only the owner can read or mutate their own blocked list.
      match /blocked/{blockedId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-friend send counter used to rank the send-sheet chip row by
      // interaction frequency. Entirely private to the owner.
      match /sendStats/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Incoming friend requests: a sender creates
      // /users/{recipientUid}/friendRequests/{senderUid}. Only the recipient
      // can read the list; either party may delete (accept/decline or cancel).
      match /friendRequests/{senderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == senderId
          && !isBlockedBy(userId, request.auth.uid);
        allow delete: if request.auth != null
          && (request.auth.uid == senderId || request.auth.uid == userId);
        allow update: if false;
      }

      // Sender-owned mirror of pending outgoing requests. This lets the sender
      // reload pending recipients and send songs before the request is accepted.
      match /outgoingFriendRequests/{targetId} {
        allow read, create, update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == targetId);
      }

      // User-owned mixtapes (Pinterest-style boards of saved songs). Each
      // mixtape doc owns an embedded `songs` subcollection that mirrors
      // the same Song shape used by shares and chat messages, so cover
      // mosaic loads don't pay an N+1 cost. Fully private to the owner —
      // mixtapes are never shared cross-user in v1.
      match /mixtapes/{mixtapeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        match /songs/{songId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Per-song "where is this saved" index. Keyed by song id; value is
      // `{ mixtapeIds: [...], updatedAt }`. Lets SaveService answer "is
      // this song saved anywhere?" without scanning every mixtape.
      match /savedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow get: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /tokenCache/{doc} {
      allow read, write: if false;
    }

    match /shares/{shareId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && !isBlockedBy(request.resource.data.recipientId, request.auth.uid);
      allow update, delete: if request.auth != null &&
        (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    // Mixtape shares — same security model as `shares` but stored in a
    // dedicated collection so listeners can scope to their own type
    // and the schema (full embedded mixtape with songs[]) doesn't have
    // to overload the song-share document. Sender or recipient may
    // delete; only the sender may create; both may read.
    match /mixtapeShares/{shareId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && !isBlockedBy(request.resource.data.recipientId, request.auth.uid);
      allow update, delete: if request.auth != null &&
        (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    // Album shares — same model as mixtape shares.
    match /albumShares/{shareId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && !isBlockedBy(request.resource.data.recipientId, request.auth.uid);
      allow update, delete: if request.auth != null &&
        (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /conversations/{convId} {
      // resource is null when the document does not exist.
      // Allow get on missing docs so clients can do get-then-create.
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      // Update: any participant of a 2-person DM may write. The legitimate
      // cross-participant write is `sendMessage`, which atomically bumps
      // the OTHER participant's `unreadCount_<otherUid>` while updating
      // `lastMessageText` / `lastMessageTimestamp` / `songStreakCount`
      // and (now) the writer's own `lastReadAt_<myUid>` for read receipts.
      // Constraining to "self-scoped fields only" would break that
      // transaction, so we keep the participant-trust model and rely on
      // the message-level rule below to prevent reaction spoofing.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && !isBlockedBy(otherParticipant(convId, request.auth.uid), request.auth.uid);

        // Self-scoped reaction edits. A participant may add, change, or
        // remove ONLY their own entry in the `reactions` map (keyed by
        // their own Firebase UID). No other field on the message may
        // change in the same write — guaranteed by the
        // affectedKeys().hasOnly(['reactions']) clause — and no entry
        // for any other UID may be touched, guaranteed by the inner map
        // diff. The .get('reactions', {}) defaults make this work for
        // both freshly reacted-to messages (where `reactions` didn't
        // exist before) and follow-up edits (where it does).
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          && request.resource.data.get('reactions', {})
              .diff(resource.data.get('reactions', {}))
              .affectedKeys()
              .hasOnly([request.auth.uid]);
      }
    }

    // Songs queued for contacts who haven't signed up yet. Clients may only
    // CREATE shares they personally sent; reads/updates/deletes happen
    // exclusively from Cloud Functions via the admin SDK.
    match /pendingShares/{phone}/shares/{shareId} {
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.keys().hasAll(['senderId', 'song', 'createdAt']);
      allow read, update, delete: if false;
    }

    // Claim-retry requests: a signed-in user asks the server to re-run the
    // pending-shares fan-out for their own UID. Processed and deleted by the
    // onClaimRequest Cloud Function.
    match /claimRequests/{reqId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Editorial album-art lists powering the Discovery background grid.
    // Any authenticated user can read the curated document; writes are
    // restricted to Cloud Functions / admin SDK.
    match /curatedGrids/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User reports (App Store Guideline 1.2 UGC requirement). Anyone signed
    // in can submit a report; only Cloud Functions / admins can read or
    // moderate them.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.keys().hasAll(['reporterUid', 'targetUid', 'targetType', 'createdAt']);
      allow read, update, delete: if false;
    }

    // Curated Discover (Home) mixtape feed. Public read so the Pinterest
    // grid can load before sign-in; writes are console/admin only (client
    // cannot mutate — Bobby edits documents in the Firebase console).
    match /featured_mixtapes/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Global Spotify resolution cache keyed by SHA-256 of the normalized
    // Apple Music song URL. One document per unique song, shared across
    // the whole user base. Any authenticated user may read (cache check
    // before a network call) and write (persist a successful resolution
    // so every other user skips the upstream API on subsequent views).
    // Deletes are admin-only; cache entries never need client eviction.
    match /spotifyResolutions/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(['trackId', 'spotifyURL', 'resolvedAt'])
        && request.resource.data.trackId is string
        && request.resource.data.spotifyURL is string;
      allow delete: if false;
    }
  }
}
