rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // True when `recipient` has added `sender` to their blocked subcollection.
    // Used to forbid blocked users from writing into the blocker's inboxes.
    function isBlockedBy(recipient, sender) {
      return exists(/databases/$(database)/documents/users/$(recipient)/blocked/$(sender));
    }

    // For 2-person DMs, returns the non-sender participant uid.
    function otherParticipant(convId, senderUid) {
      let p = get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      return p[0] == senderUid ? p[1] : p[0];
    }

    function isShareParticipant() {
      return request.auth != null
        && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    function isSafeShareUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['song', 'recipientListenedAt', 'recipientListenSources'])
        && (!changed.hasAny(['song'])
          || request.resource.data.song.diff(resource.data.song).affectedKeys().hasOnly(['spotifyURI']));
    }

    function hasAcceptedFriendship(sender, recipient) {
      return exists(/databases/$(database)/documents/users/$(sender)/friends/$(recipient));
    }

    // -------- User profile field allowlist --------
    //
    // Fields the client may set/update on its own public `users/{uid}` doc.
    // Reserved server-controlled fields (friendCount, friendLimit, invitedBy,
    // fcmToken, subscriptionTier, etc.) are deliberately NOT in this list,
    // so a compromised client can't grant itself extra friend slots, fake
    // subscription state, or move FCM tokens into the public-readable doc.
    function userDocClientWriteableFields() {
      return [
        'firstName', 'lastName', 'username',
        'notificationsEnabled', 'preferredMusicService',
        'avatarURL', 'avatarColor', 'theme',
        'tasteGenres', 'tasteArtists',
        'createdAt', 'updatedAt'
      ];
    }

    // Per-user friend cap. Default 20 — can be elevated for a single
    // account (e.g. premium subscription) by setting `friendLimit` on
    // their `users/{uid}` doc via the Admin SDK / Cloud Function.
    //
    // Enforced as a soft cap: rules check the count BEFORE the write,
    // and the `onFriendCreated` Cloud Function maintains `friendCount`
    // on each side. Two near-simultaneous adds could land one over
    // the cap (acceptable slop for a UX limit, not a security
    // boundary). Hard cap can be added later by moving friend creation
    // through a Cloud Function callable.
    function isUnderFriendCap(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId)).data;
      return userDoc.get('friendCount', 0) < userDoc.get('friendLimit', 20);
    }

    match /users/{userId} {
      allow read: if request.auth != null;

      // Create + update must use only client-writeable fields. Reserved
      // server fields stay locked.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(userDocClientWriteableFields());
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(userDocClientWriteableFields());
      allow delete: if false;

      match /likes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Song-level likes (the heart on any song card + the Liked mixtape).
      // Fully owner-scoped, same posture as `likes`.
      match /likedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Private account metadata. Keep tokens/phone out of the public profile
      // doc, which remains readable for username search and display.
      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /friends/{friendId} {
        // Owner has full read/update/delete. The peer (the "other user"
        // in the friendship) may CREATE and DELETE their own mirrored
        // row — what makes bidirectional add/unfriend work from a single
        // client — but cannot read each other's friend lists or
        // overwrite arbitrary fields.
        //
        // CREATE now requires:
        //   1. Evidence the friendship was actually requested by the
        //      OTHER party (cross-doc exists() of the matching
        //      friendRequests / outgoingFriendRequests doc). This shuts
        //      down the forge-yourself-into-someone's-friends-list
        //      vector that the previous open create rule allowed.
        //   2. The OWNER (userId) is under their per-user friend cap.
        //   3. The owner has not blocked the peer.
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == friendId);

        allow create: if request.auth != null
          && isUnderFriendCap(userId)
          && (
            // Path A: the OWNER is creating their own friends/<friend>
            // row, typically because they pressed "Accept". A pending
            // request from `friendId` to `userId` (sender=friendId,
            // recipient=userId) must exist as proof.
            (
              request.auth.uid == userId
              && exists(/databases/$(database)/documents/users/$(userId)/friendRequests/$(friendId))
            )
            // Path B: the PEER is creating the mirror row on the other
            // user's side. Their own outgoing-request mirror at
            // /users/{userId}/outgoingFriendRequests/{peerUid} must
            // exist, proving `userId` was the recipient of an
            // outstanding request from the peer.
            || (
              request.auth.uid == friendId
              && exists(/databases/$(database)/documents/users/$(userId)/outgoingFriendRequests/$(request.auth.uid))
              && !isBlockedBy(userId, request.auth.uid)
            )
          );
      }

      // Only the owner can read or mutate their own blocked list.
      match /blocked/{blockedId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-friend send counter used to rank the send-sheet chip row by
      // interaction frequency. Entirely private to the owner.
      match /sendStats/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Incoming friend requests: a sender creates
      // /users/{recipientUid}/friendRequests/{senderUid}. Only the recipient
      // can read the list; either party may delete (accept/decline or cancel).
      match /friendRequests/{senderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == senderId
          && !isBlockedBy(userId, request.auth.uid);
        allow delete: if request.auth != null
          && (request.auth.uid == senderId || request.auth.uid == userId);
        allow update: if false;
      }

      // Sender-owned mirror of pending outgoing requests. This lets the sender
      // reload pending recipients while keeping delivery blocked until accept.
      match /outgoingFriendRequests/{targetId} {
        allow read, create, update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == targetId);
      }

      // Songs selected for an existing Riff user before they accept the friend
      // request. Only the sender can create/read/delete these queue rows; a
      // Cloud Function delivers them into /shares after friendship acceptance.
      match /pendingFriendShares/{queuedShareId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.senderId == userId
          && request.resource.data.recipientId is string
          && exists(/databases/$(database)/documents/users/$(userId)/outgoingFriendRequests/$(request.resource.data.recipientId))
          && !hasAcceptedFriendship(userId, request.resource.data.recipientId)
          && !isBlockedBy(request.resource.data.recipientId, userId);
        allow update: if false;
      }

      // Index of unique song IDs the user has ever sent, used by the
      // onNewShare Cloud Function to maintain uniqueSongsSentCount. Owner
      // may read for diagnostics; all writes are Cloud Function only.
      match /sentSongIndex/{songId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // User-owned mixtapes (Pinterest-style boards of saved songs). Each
      // mixtape doc owns an embedded `songs` subcollection that mirrors
      // the same Song shape used by shares and chat messages, so cover
      // mosaic loads don't pay an N+1 cost. Fully private to the owner —
      // mixtapes are never shared cross-user in v1.
      match /mixtapes/{mixtapeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        match /songs/{songId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Per-song "where is this saved" index. Keyed by song id; value is
      // `{ mixtapeIds: [...], updatedAt }`. Lets SaveService answer "is
      // this song saved anywhere?" without scanning every mixtape.
      match /savedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow get: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /tokenCache/{doc} {
      allow read, write: if false;
    }

    match /pushDedupe/{doc} {
      allow read, write: if false;
    }

    match /claimRequestThrottle/{doc} {
      allow read, write: if false;
    }

    match /shares/{shareId} {
      allow read: if isShareParticipant();
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && hasAcceptedFriendship(request.auth.uid, request.resource.data.recipientId)
        && !isBlockedBy(request.resource.data.recipientId, request.auth.uid);
      allow update: if isShareParticipant() && isSafeShareUpdate();
      allow delete: if isShareParticipant();
    }

    // Mixtape shares — same security model as `shares` but stored in a
    // dedicated collection so listeners can scope to their own type
    // and the schema (full embedded mixtape with songs[]) doesn't have
    // to overload the song-share document. Sender or recipient may
    // delete; only the sender may create; both may read.
    match /mixtapeShares/{shareId} {
      allow read: if isShareParticipant();
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && hasAcceptedFriendship(request.auth.uid, request.resource.data.recipientId)
        && !isBlockedBy(request.resource.data.recipientId, request.auth.uid);
      allow update: if false;
      allow delete: if isShareParticipant();
    }

    // Album shares — same model as mixtape shares.
    match /albumShares/{shareId} {
      allow read: if isShareParticipant();
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && hasAcceptedFriendship(request.auth.uid, request.resource.data.recipientId)
        && !isBlockedBy(request.resource.data.recipientId, request.auth.uid);
      allow update: if false;
      allow delete: if isShareParticipant();
    }

    // -------- Conversation field allowlist --------
    //
    // Each participant may update a precise allowlist of fields. The
    // legitimate cross-participant write is "sender bumps OTHER's
    // unreadCount" — every other cross-write (e.g. spoofing the
    // OTHER user's lastReadAt timestamp to fake a read receipt) is
    // rejected here.
    //
    // `lastReadAt_<uid>` may only be written by `<uid>` themselves —
    // it powers the iMessage-style "Read" indicator so faking it
    // would let a sender display "Read" on their own bubble.
    function conversationUpdateAllowedKeys(participants, me) {
      let other = participants[0] == me ? participants[1] : participants[0];
      return [
        'lastMessageText',
        'lastMessageTimestamp',
        'lastMessageSenderId',
        'songStreakCount',
        'songStreakLastDay',
        'songMessageCount',
        'participantNames',
        'updatedAt',
        'lastReadAt_' + me,
        'unreadCount_' + me,
        'unreadCount_' + other
      ];
    }

    match /conversations/{convId} {
      // resource is null when the document does not exist.
      // Allow get on missing docs so clients can do get-then-create.
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // Update: any participant of a 2-person DM may write, but only
      // to the explicitly-allowed set of fields. See
      // `conversationUpdateAllowedKeys` above.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(conversationUpdateAllowedKeys(resource.data.participants, request.auth.uid));

      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        // Length cap on `text` enforced server-side as a safety net even
        // though the client truncates. 2000 chars covers any reasonable
        // human message and shuts down megabyte-payload abuse vectors.
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && !isBlockedBy(otherParticipant(convId, request.auth.uid), request.auth.uid)
          && (
            !('text' in request.resource.data.keys())
            || (request.resource.data.text is string
                && request.resource.data.text.size() <= 2000)
          );

        // Self-scoped reaction edits. A participant may add, change, or
        // remove ONLY their own entry in the `reactions` map (keyed by
        // their own Firebase UID). No other field on the message may
        // change in the same write — guaranteed by the
        // affectedKeys().hasOnly(['reactions']) clause — and no entry
        // for any other UID may be touched, guaranteed by the inner map
        // diff. The .get('reactions', {}) defaults make this work for
        // both freshly reacted-to messages (where `reactions` didn't
        // exist before) and follow-up edits (where it does).
        //
        // The emoji value is constrained to the iMessage-style set the
        // client UI offers (six tapback options). Any other string is
        // rejected to prevent reaction abuse (e.g. injecting a slur).
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          && request.resource.data.get('reactions', {})
              .diff(resource.data.get('reactions', {}))
              .affectedKeys()
              .hasOnly([request.auth.uid])
          && (
            !(request.auth.uid in request.resource.data.get('reactions', {}))
            || (request.resource.data.reactions[request.auth.uid] is string
                && request.resource.data.reactions[request.auth.uid] in
                  ['❤️', '👍', '👎', '😂', '‼️', '❓'])
          );
      }
    }

    // Songs queued for contacts who haven't signed up yet. Clients may only
    // CREATE shares they personally sent; reads/updates/deletes happen
    // exclusively from Cloud Functions via the admin SDK.
    match /pendingShares/{phone}/shares/{shareId} {
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.keys().hasAll(['senderId', 'song', 'createdAt']);
      allow read, update, delete: if false;
    }

    // Claim-retry requests: a signed-in user asks the server to re-run the
    // pending-shares fan-out for their own UID. Processed and deleted by the
    // onClaimRequest Cloud Function.
    match /claimRequests/{reqId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Editorial album-art lists powering the Discovery background grid.
    // Any authenticated user can read the curated document; writes are
    // restricted to Cloud Functions / admin SDK.
    match /curatedGrids/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User reports (App Store Guideline 1.2 UGC requirement). Anyone signed
    // in can submit a report; only Cloud Functions / admins can read or
    // moderate them.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.keys().hasAll(['reporterUid', 'targetUid', 'targetType', 'createdAt']);
      allow read, update, delete: if false;
    }

    // Curated Discover (Home) mixtape feed. Public read so the Pinterest
    // grid can load before sign-in; writes are console/admin only (client
    // cannot mutate — Bobby edits documents in the Firebase console).
    match /featured_mixtapes/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Curated Discover (Home) song feed. Public read matches featured
    // mixtapes; writes remain console/admin only.
    match /featured_songs/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Invite codes gate the new-user signup flow. The client never
    // touches these directly — validation + redemption + minting go
    // through the `validateInviteCode` / `redeemInviteCode` /
    // `generateInviteCode` callables, which run with admin privileges.
    // Locking everything down here prevents enumeration even from
    // authenticated clients.
    //
    // Doc shape (`inviteCodes/{CODE_UPPER}`):
    //   {
    //     // Original / always-present
    //     disabled?:   bool,
    //     redeemed?:   bool,
    //     redeemedBy?: string,         // last redeemer's uid
    //     redeemedAt?: timestamp,
    //     expiresAt?:  timestamp,
    //     maxUses?:    number (default 1),
    //     useCount?:   number (default 0),
    //
    //     // Phase B additions (all optional, backward-compatible)
    //     kind?:         "personal" | "creator" | "admin"   // default "personal"
    //     createdByUid?: string                              // attribution target
    //     campaign?:     string                              // free-form tag
    //
    //     // Rotation bookkeeping (written by seed --rotate)
    //     rotatedFrom?: string,
    //     rotatedTo?:   string,
    //     rotatedAt?:   timestamp,
    //   }
    match /inviteCodes/{code} {
      allow read, write: if false;
    }

    // Global Spotify resolution cache keyed by SHA-256 of the normalized
    // Apple Music song URL. One document per unique song, shared across
    // the whole user base. Reads remain open to any signed-in client
    // (cache hit before a network call). Writes are now ADMIN-ONLY: the
    // `resolveSpotifyTrack` Cloud Function persists successful matches
    // server-side, which closes the previous client-write cache-poisoning
    // vector where any signed-in user could overwrite a song's resolution
    // with a spam link.
    match /spotifyResolutions/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Per-UID rate-limit / abuse counters maintained server-side. Clients
    // cannot read or write — the values exist only to be evaluated by
    // Cloud Functions and (eventually) by rules for enforcement.
    match /usageCounters/{uid} {
      allow read, write: if false;
    }
  }
}
